# --- Local Docker Compose Environment Variables Template ---
# Copy this file to '.env' and fill in your actual secrets before running docker-compose.
# DO NOT commit the '.env' file containing actual secrets to git!

# Database Configuration (Supabase PostgreSQL)
SPRING_DATASOURCE_URL=jdbc:postgresql://aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres.saeieulilltuqqkqrcoy
SPRING_DATASOURCE_PASSWORD=your_supabase_database_password_here

# Supabase Storage Configuration
SUPABASE_URL=https://saeieulilltuqqkqrcoy.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_BUCKET_NAME=documents

# Google Gemini AI API Configuration
AI_API_KEY=your_gemini_api_key_here
AI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-flash-latest:generateContent
AI_MODEL=gemini-flash-latest

# JWT Signing Secret (Generate a strong key for production!)
JWT_SECRET=your-very-secure-and-long-secret-key-for-jwt-generation-here
